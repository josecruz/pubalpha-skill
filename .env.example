# Copy to .env and fill in. .env is gitignored — never commit real keys.

# CoinMarketCap Pro REST API key (paid tier). Used by scripts/sources/cmc.py for the
# deterministic data path (quotes, OHLCV, content, community, categories, global, DEX).
CMC_PRO_API_KEY=your_cmc_pro_api_key_here

# OPTIONAL — paste.trade sanctioned access token/cookie, if you have legitimate access.
# Leave blank to use only the robots.txt-allowed public surface.
PASTE_TRADE_TOKEN=
